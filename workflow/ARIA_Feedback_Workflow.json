    {
      "parameters": {
        "jsCode": "const rating = $('On form submission').item.json['How useful was today\\'s briefing?'];\nconst comments = $('On form submission').item.json['Any comments?'] || 'No comments provided';\n\nconst feedback = {\n  rating: rating,\n  comments: comments,\n  submittedAt: new Date().toISOString(),\n  message: rating >= 4 \n    ? \"Great! ARIA will keep up the good work.\" \n    : rating >= 3 \n    ? \"Thanks! ARIA will try to improve your briefings.\"\n    : \"Sorry to hear that! ARIA will significantly adjust future briefings.\"\n};\n\nreturn [{ json: feedback }];"
      },
